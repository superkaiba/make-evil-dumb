+function _hotReloadParseEnv(env) {
+  const re = /^SSH_SERVER_(.+)_HOST$/;
+  const out = {};
+  for (const [key, value] of Object.entries(env)) {
+    const m = key.match(re);
+    if (!m) continue;
+    const suffix = m[1];
+    const name = suffix.toLowerCase();
+    out[name] = {
+      name,
+      host: value,
+      user: env[`SSH_SERVER_${suffix}_USER`],
+      password: env[`SSH_SERVER_${suffix}_PASSWORD`],
+      keyPath: env[`SSH_SERVER_${suffix}_KEYPATH`],
+      passphrase: env[`SSH_SERVER_${suffix}_PASSPHRASE`],
+      port: parseInt(env[`SSH_SERVER_${suffix}_PORT`] || '22'),
+      defaultDir: env[`SSH_SERVER_${suffix}_DEFAULT_DIR`],
+      sudoPassword: env[`SSH_SERVER_${suffix}_SUDO_PASSWORD`],
+      description: env[`SSH_SERVER_${suffix}_DESCRIPTION`],
+      platform:
+        (env[`SSH_SERVER_${suffix}_PLATFORM`] || '').toLowerCase() || undefined,
+      proxyJump: env[`SSH_SERVER_${suffix}_PROXYJUMP`],
